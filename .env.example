# Spotify OAuth app credentials — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# NextAuth — generate with `openssl rand -base64 32`
NEXTAUTH_SECRET=
# Spotify no longer allows `localhost` as a redirect URI — use the 127.0.0.1
# loopback and register `http://127.0.0.1:3000/api/auth/callback/spotify` in the
# dashboard. Set this to your real HTTPS URL in production.
NEXTAUTH_URL=http://127.0.0.1:3000
